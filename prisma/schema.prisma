// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb" // o postgresql, etc.
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String     @unique
  image     String?
  role      String     @default("user") // "admin" o "user"
  isBlocked Boolean    @default(false)
  createdAt DateTime   @default(now())

  // Relaciones
  comments  Comment[]
  reactions Reaction[]

  @@map("users")
}

model Category {
  id    String @id @default(auto()) @map("_id") @db.ObjectId
  name  String @unique
  blogs Blog[]

  @@map("categories")
}

model Blog {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  title        String
  content      String
  description  String
  imageUrl     String?
  readingTime  String?
  videoUrl     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relación con Categoría
  categoryId   String   @db.ObjectId
  category     Category @relation(fields: [categoryId], references: [id])

  // Relaciones con Actividad
  comments     Comment[]
  reactions    Reaction[]

  @@map("blogs")
}

model Comment {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  content   String
  blogId    String   @db.ObjectId
  authorId  String   @db.ObjectId // <--- DEBE ESTAR ESTA LÍNEA
  createdAt DateTime @default(now())

  // Relaciones
  blog      Blog     @relation(fields: [blogId], references: [id])
  author    User     @relation(fields: [authorId], references: [id]) // <--- Y ESTA TAMBIÉN
}

model Reaction {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  type      String   // "LIKE" o "DISLIKE"
  createdAt DateTime @default(now())

  // Relación con Blog
  blogId    String   @db.ObjectId
  blog      Blog     @relation(fields: [blogId], references: [id], onDelete: Cascade)

  // Relación con Usuario
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([blogId, userId]) // Un usuario solo puede reaccionar una vez por cada blog
  @@map("reactions")
}

model LiveConfig {
  id        String   @id @map("_id")
  isLive    Boolean  @default(false)
  youtubeId String
  title     String   @default("Transmisión en Vivo")
  updatedAt DateTime @updatedAt

  @@map("live_configs") // Esto fuerza a Prisma a usar la tabla que ya tienes en Compass
}