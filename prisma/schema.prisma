model User {
  id        String     @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String     @unique
  image     String?
  role      String     @default("user") // "admin" o "user"
  status    String     @default("active") // "active" o "suspended"
  createdAt DateTime   @default(now())

  // Relaciones
  comments  Comment[]
  reactions Reaction[]

  @@map("users")
}

model Category {
  id    String @id @default(auto()) @map("_id") @db.ObjectId
  name  String @unique
  blogs Blog[]

  @@map("categories")
}

model Blog {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  title        String
  content      String
  description  String
  imageUrl     String?
  readingTime  String?
  videoUrl     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relación con Categoría
  categoryId   String   @db.ObjectId
  category     Category @relation(fields: [categoryId], references: [id])

  // Relaciones con Actividad
  comments     Comment[]
  reactions    Reaction[]

  @@map("blogs")
}

model Comment {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  content   String
  createdAt DateTime @default(now())

  // Relación con Blog
  blogId    String   @db.ObjectId
  blog      Blog     @relation(fields: [blogId], references: [id], onDelete: Cascade)

  // Relación con Usuario
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("comments")
}

model Reaction {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  type      String   // "LIKE" o "DISLIKE"
  createdAt DateTime @default(now())

  // Relación con Blog
  blogId    String   @db.ObjectId
  blog      Blog     @relation(fields: [blogId], references: [id], onDelete: Cascade)

  // Relación con Usuario
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([blogId, userId]) // Un usuario solo puede reaccionar una vez por cada blog
  @@map("reactions")
}

model LiveConfig {
  id        String   @id @default("main-live") @map("_id")
  isLive    Boolean  @default(false)
  youtubeId String
  title     String?
  updatedAt DateTime @updatedAt

  @@map("live_configs")
}